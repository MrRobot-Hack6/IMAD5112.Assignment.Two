<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:id="@+id/main"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="?android:attr/colorEdgeEffect"
    tools:context=".MainActivity">

    <TextView
        android:id="@+id/textView3"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="15dp"
        android:layout_marginTop="15dp"
        android:text="Hack OR Myth Quiz Game"
        android:textColor="#00C853"
        android:textSize="24sp"
        android:textStyle="bold|italic"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toTopOf="parent" />

    <TextView
        android:id="@+id/txtQuestion"
        android:layout_width="384dp"
        android:layout_height="97dp"
        android:layout_marginStart="15dp"
        android:layout_marginTop="30dp"
        android:text="Question Display:"
        android:textAlignment="center"
        android:textColor="#00C853"
        android:textSize="16sp"
        android:textStyle="italic"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/textView3" />

    <RadioGroup
        android:id="@+id/rbGroup"
        android:layout_width="98dp"
        android:layout_height="97dp"
        android:layout_marginStart="150dp"
        android:layout_marginTop="15dp"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtQuestion">

        <RadioButton
            android:id="@+id/rbHack"
            android:layout_width="87dp"
            android:layout_height="wrap_content"
            android:text="Hack"
            android:textColor="#00C853" />

        <RadioButton
            android:id="@+id/rbMyth"
            android:layout_width="88dp"
            android:layout_height="wrap_content"
            android:text="Myth"
            android:textColor="#00C853" />
    </RadioGroup>

    <Button
        android:id="@+id/btnNext"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="50dp"
        android:layout_marginTop="219dp"
        android:backgroundTint="#F8F6F6"
        android:text="Next"
        android:textColor="#00C853"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintTop_toBottomOf="@+id/txtQuestion" />

    <Button
        android:id="@+id/btnBack"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginStart="136dp"
        android:layout_marginTop="109dp"
        android:backgroundTint="#FBF9F9"
        android:text="Back"
        android:textColor="#00C853"
        app:layout_constraintStart_toEndOf="@+id/btnNext"
        app:layout_constraintTop_toBottomOf="@+id/rbGroup" />

</androidx.constraintlayout.widget.ConstraintLayout>